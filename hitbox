-- ============ SLIDER FUNCTIONS ============
local function UpdateSizeSlider()
	local percent = (HitboxSize - 5) / 35
	sizeSliderFill.Size = UDim2.new(percent, 0, 1, 0)
	sizeSliderBtn.Position = UDim2.new(percent, -8, 0.5, -8)
end

local function UpdateTransSlider()
	local percent = HitboxTransparency
	transSliderFill.Size = UDim2.new(percent, 0, 1, 0)
	transSliderBtn.Position = UDim2.new(percent, -8, 0.5, -8)
end

-- Size Slider Drag
local sizeDragging = false
sizeSliderBtn.MouseButton1Down:Connect(function()
	sizeDragging = true
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		sizeDragging = false
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if sizeDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local absolutePos = sizeSlider.AbsolutePosition
		local absoluteSize = sizeSlider.AbsoluteSize
		local mouseX = input.Position.X
		
		local percent = math.clamp((mouseX - absolutePos.X) / absoluteSize.X, 0, 1)
		HitboxSize = math.round(5 + (percent * 35))
		if HitboxSize < 5 then HitboxSize = 5 end
		if HitboxSize > 40 then HitboxSize = 40 end
		
		sizeLabel.Text = "SIZE: " .. HitboxSize
		UpdateSizeSlider()
		
		if HitboxEnabled then
			ApplyHitbox()
		end
	end
end)

-- Transparency Slider Drag
local transDragging = false
transSliderBtn.MouseButton1Down:Connect(function()
	transDragging = true
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		transDragging = false
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if transDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local absolutePos = transSlider.AbsolutePosition
		local absoluteSize = transSlider.AbsoluteSize
		local mouseX = input.Position.X
		
		local percent = math.clamp((mouseX - absolutePos.X) / absoluteSize.X, 0, 1)
		HitboxTransparency = math.round(percent * 10) / 10
		if HitboxTransparency < 0 then HitboxTransparency = 0 end
		if HitboxTransparency > 1 then HitboxTransparency = 1 end
		
		transLabel.Text = "VIS: " .. HitboxTransparency
		UpdateTransSlider()
		
		if HitboxEnabled then
			ApplyHitbox()
		end
	end
end)

