-- ============ HITBOX FUNCTION ============
local function ApplyHitbox()
	if not HitboxEnabled then return end
	
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character then
			local char = player.Character
			local torso = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
			local root = char:FindFirstChild("HumanoidRootPart")
			local hum = char:FindFirstChildOfClass("Humanoid")
			
			if hum and hum.Health > 0 then
				if root then
					root.Size = Vector3.new(HitboxSize, HitboxSize, HitboxSize)
					root.Transparency = HitboxTransparency
					root.Color = Color3.fromRGB(255, 215, 0)
					root.Material = Enum.Material.Neon
					root.CanCollide = true
				end
				if torso then
					torso.Size = Vector3.new(HitboxSize, HitboxSize, HitboxSize)
					torso.Transparency = HitboxTransparency
					torso.Color = Color3.fromRGB(255, 215, 0)
					torso.Material = Enum.Material.Neon
					torso.CanCollide = true
				end
			end
		end
	end
end

local function ResetHitbox()
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character then
			local char = player.Character
			local torso = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
			local root = char:FindFirstChild("HumanoidRootPart")
			
			if root then
				root.Size = Vector3.new(2, 2, 1)
				root.Transparency = 1
				root.Color = Color3.fromRGB(255, 255, 255)
				root.Material = Enum.Material.Plastic
				root.CanCollide = true
			end
			if torso then
				torso.Size = Vector3.new(2, 2, 1)
				torso.Transparency = 0
				torso.Color = Color3.fromRGB(255, 255, 255)
				torso.Material = Enum.Material.Plastic
				torso.CanCollide = true
			end
		end
	end
end

-- ============ ESP FUNCTIONS ============
local function CreateESP(player)
	if not ESPEnabled then return end
	if not player then return end
	
	local char = player.Character
	if not char then return end
	
	local root = char:FindFirstChild("HumanoidRootPart")
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not root or not hum then return end
	
	if ESPObjects[player] then
		for _, obj in ipairs(ESPObjects[player]) do
			pcall(function() obj:Destroy() end)
		end
		ESPObjects[player] = nil
	end
	
	if ESPConnections[player] then
		pcall(function() ESPConnections[player]:Disconnect() end)
		ESPConnections[player] = nil
	end
	
	local objects = {}
	
	if OutlineESP then
		local legL = char:FindFirstChild("Left Leg") or char:FindFirstChild("LeftLowerLeg")
		local legR = char:FindFirstChild("Right Leg") or char:FindFirstChild("RightLowerLeg")
		local armL = char:FindFirstChild("Left Arm") or char:FindFirstChild("LeftUpperArm")
		local armR = char:FindFirstChild("Right Arm") or char:FindFirstChild("RightUpperArm")
		local torso = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
		local head = char:FindFirstChild("Head")
		
		local parts = {root, torso, head, legL, legR, armL, armR}
		
		for _, part in ipairs(parts) do
			if part and part.Parent then
				local outline = Instance.new("BoxHandleAdornment")
				outline.Size = part.Size + Vector3.new(0.2, 0.2, 0.2)
				outline.Adornee = part
				outline.Color3 = Color3.fromRGB(0, 255, 255)
				outline.Transparency = 0.3
				outline.ZIndex = 0
				outline.AlwaysOnTop = true
				outline.Parent = part
				table.insert(objects, outline)
				
				local glow = Instance.new("BoxHandleAdornment")
				glow.Size = part.Size + Vector3.new(0.5, 0.5, 0.5)
				glow.Adornee = part
				glow.Color3 = Color3.fromRGB(0, 150, 255)
				glow.Transparency = 0.7
				glow.ZIndex = 0
				glow.AlwaysOnTop = true
				glow.Parent = part
				table.insert(objects, glow)
			end
		end
	end
	
	if NameESP then
		local nameTag = Instance.new("BillboardGui")
		nameTag.Size = UDim2.new(0, 200, 0, 30)
		nameTag.Adornee = root
		nameTag.AlwaysOnTop = true
		nameTag.MaxDistance = 500
		nameTag.StudsOffset = Vector3.new(0, 4, 0)
		nameTag.Parent = root
		
		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1, 0, 1, 0)
		label.BackgroundTransparency = 1
		label.Text = player.Name
		label.TextColor3 = Color3.fromRGB(0, 255, 255)
		label.Font = Enum.Font.GothamBold
		label.TextSize = 14
		label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
		label.TextStrokeTransparency = 0.3
		label.Parent = nameTag
		
		table.insert(objects, nameTag)
	end
	
	if HealthESP then
		local healthTag = Instance.new("BillboardGui")
		healthTag.Size = UDim2.new(0, 200, 0, 20)
		healthTag.Adornee = root
		healthTag.AlwaysOnTop = true
		healthTag.MaxDistance = 500
		healthTag.StudsOffset = Vector3.new(0, 3, 0)
		healthTag.Parent = root
		
		local healthLabel = Instance.new("TextLabel")
		healthLabel.Size = UDim2.new(1, 0, 1, 0)
		healthLabel.BackgroundTransparency = 1
		local health = math.round(hum.Health / hum.MaxHealth * 100)
		healthLabel.Text = "HP: " .. health .. "%"
		healthLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
		healthLabel.Font = Enum.Font.GothamBold
		healthLabel.TextSize = 12
		healthLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
		healthLabel.TextStrokeTransparency = 0.3
		healthLabel.Parent = healthTag
		
		table.insert(objects, healthTag)
		
		local conn = hum:GetPropertyChangedSignal("Health"):Connect(function()
			if not hum or not hum.Parent then return end
			local newHealth = math.round(hum.Health / hum.MaxHealth * 100)
			healthLabel.Text = "HP: " .. newHealth .. "%"
			if newHealth > 60 then
				healthLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
			elseif newHealth > 30 then
				healthLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
			else
				healthLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
			end
		end)
		ESPConnections[player] = conn
	end
	
	ESPObjects[player] = objects
end

local function ClearESP()
	for player, objects in pairs(ESPObjects) do
		for _, obj in ipairs(objects) do
			pcall(function() obj:Destroy() end)
		end
	end
	ESPObjects = {}
	
	for player, conn in pairs(ESPConnections) do
		pcall(function() conn:Disconnect() end)
	end
	ESPConnections = {}
end

local function UpdateESP()
	ClearESP()
	if not ESPEnabled then return end
	
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer then
			CreateESP(player)
		end
	end
end

-- ============ PLAYER CONNECTIONS ============
local function OnCharacterAdded(player, character)
	task.wait(0.5)
	if ESPEnabled and player ~= LocalPlayer then
		CreateESP(player)
	end
end

Players.PlayerAdded:Connect(function(player)
	local charConn
	charConn = player.CharacterAdded:Connect(function(character)
		OnCharacterAdded(player, character)
	end)
	
	if player.Character then
		task.wait(0.5)
		if ESPEnabled and player ~= LocalPlayer then
			CreateESP(player)
		end
	end
end)

Players.PlayerRemoving:Connect(function(player)
	if ESPObjects[player] then
		for _, obj in ipairs(ESPObjects[player]) do
			pcall(function() obj:Destroy() end)
		end
		ESPObjects[player] = nil
	end
	if ESPConnections[player] then
		pcall(function() ESPConnections[player]:Disconnect() end)
		ESPConnections[player] = nil
	end
end)

